<?xml version="1.0" encoding="utf-8"?>
<androidx.core.widget.NestedScrollView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    tools:context=".ui.main.HomeFragment">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="25dp">

        <com.google.android.material.card.MaterialCardView
            android:id="@+id/cvTiempoMeteo"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="50dp"
            android:layout_marginBottom="25dp"
            app:cardBackgroundColor="@color/verde_principal"
            app:cardCornerRadius="25dp"
            app:cardElevation="4dp">

            <androidx.constraintlayout.widget.ConstraintLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:padding="25dp">

                <TextView
                    android:id="@+id/tvFecha"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:textColor="@color/blanco"
                    android:textSize="18sp"
                    app:layout_constraintTop_toTopOf="parent"
                    app:layout_constraintStart_toStartOf="parent" />

                <ImageView
                    android:id="@+id/ivViento"
                    android:layout_width="28dp"
                    android:layout_height="28dp"
                    android:layout_marginTop="12dp"
                    android:src="@drawable/ic_wind"
                    app:tint="@color/blanco"
                    app:layout_constraintTop_toBottomOf="@id/tvFecha"
                    app:layout_constraintStart_toStartOf="parent" />

                <TextView
                    android:id="@+id/tvVientoValor"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="8dp"
                    android:textColor="@color/blanco"
                    android:textSize="16sp"
                    app:layout_constraintBottom_toBottomOf="@id/ivViento"
                    app:layout_constraintStart_toEndOf="@id/ivViento"
                    app:layout_constraintTop_toTopOf="@id/ivViento" />

                <ImageView
                    android:id="@+id/ivHumedad"
                    android:layout_width="28dp"
                    android:layout_height="28dp"
                    android:layout_marginTop="8dp"
                    android:src="@drawable/ic_humidity"
                    app:tint="@color/blanco"
                    app:layout_constraintTop_toBottomOf="@id/ivViento"
                    app:layout_constraintStart_toStartOf="parent" />

                <TextView
                    android:id="@+id/tvHumedadValor"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="8dp"
                    android:textColor="@color/blanco"
                    android:textSize="16sp"
                    app:layout_constraintBottom_toBottomOf="@id/ivHumedad"
                    app:layout_constraintStart_toEndOf="@id/ivHumedad"
                    app:layout_constraintTop_toTopOf="@id/ivHumedad" />

                <ImageView
                    android:id="@+id/ivLluvia"
                    android:layout_width="28dp"
                    android:layout_height="28dp"
                    android:layout_marginTop="8dp"
                    android:src="@drawable/ic_rain"
                    app:tint="@color/blanco"
                    app:layout_constraintTop_toBottomOf="@id/ivHumedad"
                    app:layout_constraintStart_toStartOf="parent" />

                <TextView
                    android:id="@+id/tvLluviaValor"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="8dp"
                    android:textColor="@color/blanco"
                    android:textSize="16sp"
                    app:layout_constraintBottom_toBottomOf="@id/ivLluvia"
                    app:layout_constraintStart_toEndOf="@id/ivLluvia"
                    app:layout_constraintTop_toTopOf="@id/ivLluvia" />

                <TextView
                    android:id="@+id/tvTemperatura"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:textColor="@color/blanco"
                    android:textSize="44sp"
                    android:textStyle="bold"
                    app:layout_constraintBottom_toBottomOf="parent"
                    app:layout_constraintEnd_toEndOf="parent" />

                <ImageView
                    android:id="@+id/ivClima"
                    android:layout_width="50dp"
                    android:layout_height="50dp"
                    app:layout_constraintBottom_toTopOf="@id/tvTemperatura"
                    app:layout_constraintEnd_toEndOf="parent"
                    app:layout_constraintHorizontal_bias="1.0"
                    app:layout_constraintStart_toStartOf="@id/tvTemperatura" />

            </androidx.constraintlayout.widget.ConstraintLayout>
        </com.google.android.material.card.MaterialCardView>

        <com.google.android.material.card.MaterialCardView
            android:id="@+id/cvSaludoNivel"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="25dp"
            app:cardBackgroundColor="@color/verde_elementos"
            app:cardCornerRadius="22dp"
            app:cardElevation="0dp">

            <LinearLayout
                android:id="@+id/llUsuarioInfo"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:padding="16dp"
                android:gravity="center_vertical">

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Hola,"
                        android:textSize="14sp"
                        android:textColor="@color/gris_texto"/>

                    <TextView
                        android:id="@+id/tvSaludoNombre"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:textSize="24sp"
                        android:textColor="@color/gris_texto"
                        android:layout_marginBottom="6dp"/>

                    <TextView
                        android:id="@+id/tvXP"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:textSize="14sp"
                        android:textColor="@color/verde_principal"
                        android:layout_marginBottom="5dp"/>

                    <ProgressBar
                        android:id="@+id/pbNivel"
                        style="@style/Widget.AppCompat.ProgressBar.Horizontal"
                        android:layout_width="130dp"
                        android:layout_height="7dp"
                        android:progress="30"
                        android:max="100"
                        android:progressTint="@color/verde_principal"
                        android:progressBackgroundTint="@color/verde_casillas"/>

                </LinearLayout>

                <LinearLayout
                    android:id="@+id/llNivel"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:gravity="center"
                    android:layout_marginStart="12dp">

                    <com.google.android.material.card.MaterialCardView
                        android:layout_width="52dp"
                        android:layout_height="52dp"
                        app:cardCornerRadius="26dp"
                        app:cardBackgroundColor="@color/blanco"
                        app:cardElevation="0dp"
                        app:strokeColor="@color/verde_principal"
                        app:strokeWidth="2dp">

                        <ImageView
                            android:id="@+id/ivIconoUsuarioHome"
                            android:layout_width="52dp"
                            android:layout_height="52dp"
                            android:padding="-4dp"
                            android:scaleType="fitXY"
                            tools:ignore="ContentDescription" />

                    </com.google.android.material.card.MaterialCardView>

                    <TextView
                        android:id="@+id/tvNivel"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="6dp"
                        android:textSize="14sp"
                        android:textStyle="bold"
                        android:textColor="@color/blanco"
                        android:background="@drawable/bg_badge_level"
                        android:paddingHorizontal="12dp"
                        android:paddingVertical="3dp"/>

                </LinearLayout>

            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:weightSum="2">

            <LinearLayout
                android:id="@+id/llAccionMisplantas"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:layout_marginEnd="8dp"
                android:orientation="vertical"
                android:gravity="center"
                android:background="@drawable/bg_shortcut"
                android:padding="18dp"
                android:clickable="true"
                android:focusable="true">

                <com.google.android.material.card.MaterialCardView
                    android:layout_width="46dp"
                    android:layout_height="46dp"
                    app:cardCornerRadius="14dp"
                    app:cardBackgroundColor="@color/blanco"
                    app:cardElevation="0dp">
                    <ImageView
                        android:layout_width="24dp"
                        android:layout_height="24dp"
                        android:layout_gravity="center"
                        android:src="@drawable/ic_plant"
                        app:tint="@color/verde_principal"/>
                </com.google.android.material.card.MaterialCardView>

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Mis plantas"
                    android:textSize="14sp"
                    android:textColor="@color/verde_principal"
                    android:layout_marginTop="10dp"/>
            </LinearLayout>

            <LinearLayout
                android:id="@+id/llAccionAnadir"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:layout_marginStart="8dp"
                android:orientation="vertical"
                android:gravity="center"
                android:background="@drawable/bg_shortcut"
                android:padding="18dp"
                android:clickable="true"
                android:focusable="true">

                <com.google.android.material.card.MaterialCardView
                    android:layout_width="46dp"
                    android:layout_height="46dp"
                    app:cardCornerRadius="14dp"
                    app:cardBackgroundColor="@color/blanco"
                    app:cardElevation="0dp">
                    <ImageView
                        android:layout_width="24dp"
                        android:layout_height="24dp"
                        android:layout_gravity="center"
                        android:src="@drawable/ic_add_plant"
                        app:tint="@color/verde_principal"/>
                </com.google.android.material.card.MaterialCardView>

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Añadir planta"
                    android:textSize="14sp"
                    android:textColor="@color/verde_principal"
                    android:layout_marginTop="10dp"/>
            </LinearLayout>

        </LinearLayout>

    </LinearLayout>
</androidx.core.widget.NestedScrollView>