<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/blanco"
    android:padding="25dp">

    <ImageButton
        android:id="@+id/btnCerrar"
        android:layout_width="48dp"
        android:layout_height="48dp"
        android:layout_marginTop="25dp"
        android:background="?attr/selectableItemBackgroundBorderless"
        android:scaleType="fitCenter"
        android:src="@drawable/ic_close"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        app:tint="@color/verde_principal" />

    <TextView
        android:id="@+id/tvTituloPaso3"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="@string/diagn_stico_obtenido"
        android:textColor="@color/verde_principal"
        android:textSize="28sp"
        android:layout_marginTop="25dp"
        app:layout_constraintTop_toBottomOf="@id/btnCerrar"
        app:layout_constraintStart_toStartOf="parent" />

    <ImageView
        android:id="@+id/ivIconEstado"
        android:layout_width="24dp"
        android:layout_height="24dp"
        android:layout_marginTop="25dp"
        android:src="@drawable/ic_diagnosis"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/tvTituloPaso3"
        app:tint="@color/gris_texto" />

    <TextView
        android:id="@+id/tvLabelEstado"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginStart="16dp"
        android:text="Estado"
        android:textColor="@color/gris_texto"
        android:textSize="16sp"
        android:textStyle="bold"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toEndOf="@id/ivIconEstado"
        app:layout_constraintTop_toTopOf="@id/ivIconEstado" />

    <TextView
        android:id="@+id/tvValorEstado"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:textColor="@color/gris_texto"
        android:textSize="14sp"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="@id/tvLabelEstado"
        app:layout_constraintTop_toBottomOf="@id/tvLabelEstado" />

    <ImageView
        android:id="@+id/ivIconProblema"
        android:layout_width="24dp"
        android:layout_height="24dp"
        android:layout_marginTop="24dp"
        android:src="@drawable/ic_problem"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/tvValorEstado"
        app:tint="@color/gris_texto" />

    <TextView
        android:id="@+id/tvLabelProblema"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginStart="16dp"
        android:text="Problema detectado"
        android:textColor="@color/gris_texto"
        android:textSize="16sp"
        android:textStyle="bold"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toEndOf="@id/ivIconProblema"
        app:layout_constraintTop_toTopOf="@id/ivIconProblema" />

    <TextView
        android:id="@+id/tvValorProblema"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:textColor="@color/gris_texto"
        android:textSize="14sp"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="@id/tvLabelProblema"
        app:layout_constraintTop_toBottomOf="@id/tvLabelProblema" />

    <!-- SECCIÓN 3: DESCRIPCIÓN -->
    <ImageView
        android:id="@+id/ivIconDescripcion"
        android:layout_width="24dp"
        android:layout_height="24dp"
        android:layout_marginTop="24dp"
        android:src="@drawable/ic_description"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/tvValorProblema"
        app:tint="@color/gris_texto" />

    <TextView
        android:id="@+id/tvLabelDescripcion"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginStart="16dp"
        android:text="Descripción"
        android:textColor="@color/gris_texto"
        android:textSize="16sp"
        android:textStyle="bold"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toEndOf="@id/ivIconDescripcion"
        app:layout_constraintTop_toTopOf="@id/ivIconDescripcion" />

    <TextView
        android:id="@+id/tvValorDescripcion"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:textColor="@color/gris_texto"
        android:textSize="14sp"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="@id/tvLabelDescripcion"
        app:layout_constraintTop_toBottomOf="@id/tvLabelDescripcion" />

    <!-- SECCIÓN 4: CONSEJOS -->
    <ImageView
        android:id="@+id/ivIconConsejos"
        android:layout_width="24dp"
        android:layout_height="24dp"
        android:layout_marginTop="24dp"
        android:src="@drawable/ic_ballot"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/tvValorDescripcion"
        app:tint="@color/gris_texto" />

    <TextView
        android:id="@+id/tvLabelConsejos"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginStart="16dp"
        android:text="Consejos"
        android:textColor="#333333"
        android:textSize="16sp"
        android:textStyle="bold"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toEndOf="@id/ivIconConsejos"
        app:layout_constraintTop_toTopOf="@id/ivIconConsejos" />

    <TextView
        android:id="@+id/tvValorConsejos"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:textColor="@color/gris_texto"
        android:textSize="14sp"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="@id/tvLabelConsejos"
        app:layout_constraintTop_toBottomOf="@id/tvLabelConsejos" />

    <LinearLayout
        android:id="@+id/botones"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:layout_marginBottom="25dp"
        android:paddingBottom="10dp"
        android:paddingTop="10dp"
        android:paddingStart="10dp"
        android:paddingEnd="10dp"
        android:clipToPadding="false"
        android:clipChildren="false"
        app:layout_constraintBottom_toBottomOf="parent">

        <androidx.appcompat.widget.AppCompatButton
            android:id="@+id/btnAtras"
            android:layout_width="0dp"
            android:layout_height="50dp"
            android:layout_weight="1"
            android:layout_marginEnd="10dp"
            android:text="Atrás"
            android:textSize="16sp"
            android:textAllCaps="false"
            android:textColor="@color/blanco"
            android:background="@drawable/btn_back" />

        <androidx.appcompat.widget.AppCompatButton
            android:id="@+id/btnSiguientePaso4"
            android:layout_width="0dp"
            android:layout_height="50dp"
            android:layout_weight="1"
            android:layout_marginStart="50dp"
            android:text="Siguiente"
            android:textSize="16sp"
            android:textAllCaps="false"
            android:textColor="@color/blanco"
            android:background="@drawable/btn_next" />
    </LinearLayout>

</androidx.constraintlayout.widget.ConstraintLayout>