<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/blanco"
    android:padding="25dp">

    <ImageButton
        android:id="@+id/btnCerrar"
        android:layout_width="48dp"
        android:layout_height="48dp"
        android:layout_marginTop="25dp"
        android:background="?attr/selectableItemBackgroundBorderless"
        android:padding="0dp"
        android:scaleType="fitCenter"
        android:src="@drawable/ic_close"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        app:tint="@color/verde_principal" />

    <TextView
        android:id="@+id/tvTituloPaso1"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="@string/identifica_tu_planta"
        android:textColor="@color/verde_principal"
        android:textSize="28sp"
        android:layout_marginTop="25dp"
        app:layout_constraintTop_toBottomOf="@id/btnCerrar"
        app:layout_constraintStart_toStartOf="parent" />

    <TextView
        android:id="@+id/tvDescripcionPaso1"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:text="@string/toma_una_foto_de_tu_planta_o_selecciona_una_imagen_de_tu_galer_a"
        android:textColor="@color/gris_texto"
        android:textSize="16sp"
        android:layout_marginTop="25dp"
        app:layout_constraintTop_toBottomOf="@id/tvTituloPaso1"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <LinearLayout
        android:id="@+id/llContenedorBotones"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center"
        app:layout_constraintVertical_bias="0.4"
        app:layout_constraintTop_toBottomOf="@id/tvDescripcionPaso1"
        app:layout_constraintBottom_toTopOf="@id/btnSiguientePaso1"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <ImageView
            android:id="@+id/btnCamara"
            android:layout_width="100dp"
            android:layout_height="100dp"
            android:padding="20dp"
            android:background="@drawable/bg_rounded"
            android:src="@drawable/ic_add_photo"
            app:tint="@color/verde_seleccionado" />

        <View
            android:layout_width="80dp"
            android:layout_height="1dp" />

        <ImageView
            android:id="@+id/btnGaleria"
            android:layout_width="100dp"
            android:layout_height="100dp"
            android:padding="20dp"
            android:background="@drawable/bg_rounded"
            android:src="@drawable/ic_image"
            app:tint="@color/verde_seleccionado" />
    </LinearLayout>

    <androidx.appcompat.widget.AppCompatButton
        android:id="@+id/btnSiguientePaso1"
        android:layout_width="150dp"
        android:layout_height="50dp"
        android:layout_marginBottom="25dp"
        android:text="Siguiente"
        android:textColor="@color/blanco"
        android:textSize="16sp"
        android:textAllCaps="false"
        android:background="@drawable/btn_next"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

</androidx.constraintlayout.widget.ConstraintLayout>