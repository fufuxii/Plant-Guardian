<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/blanco"
    android:padding="25dp">

    <ImageButton
        android:id="@+id/btnCerrar"
        android:layout_width="48dp"
        android:layout_height="48dp"
        android:layout_marginTop="25dp"
        android:background="?attr/selectableItemBackgroundBorderless"
        android:scaleType="fitCenter"
        android:src="@drawable/ic_close"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        app:tint="@color/verde_principal" />

    <TextView
        android:id="@+id/tvTituloPaso3"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="@string/d_nde_est_tu_planta"
        android:textColor="@color/verde_principal"
        android:textSize="28sp"
        android:layout_marginTop="25dp"
        app:layout_constraintTop_toBottomOf="@id/btnCerrar"
        app:layout_constraintStart_toStartOf="parent" />

    <com.google.android.material.textfield.TextInputLayout
        android:id="@+id/tilPlantaLugar"
        style="@style/Widget.MaterialComponents.TextInputLayout.FilledBox.ExposedDropdownMenu"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="25dp"
        app:hintEnabled="false"
        app:placeholderTextColor="@color/gris_texto"
        app:boxBackgroundColor="@color/verde_elementos"
        app:boxStrokeWidth="0dp"
        app:boxStrokeWidthFocused="0dp"
        app:endIconTint="@color/verde_principal"
        app:layout_constraintTop_toBottomOf="@id/tvTituloPaso3">

        <AutoCompleteTextView
            android:id="@+id/actvPlantaLugar"
            android:layout_width="match_parent"
            android:layout_height="55dp"
            android:gravity="center_vertical"
            android:paddingTop="0dp"
            android:paddingBottom="0dp"
            android:hint="@string/selecciona_un_lugar"
            android:textColor="@color/gris_texto"
            android:textColorHint="@color/gris_texto_hint"
            android:inputType="none"
            android:textSize="16sp"
            android:popupBackground="@drawable/bg_dropdown" />

    </com.google.android.material.textfield.TextInputLayout>

    <LinearLayout
        android:id="@+id/botones"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:layout_marginBottom="25dp"
        android:paddingBottom="10dp"
        android:paddingTop="10dp"
        android:paddingStart="10dp"
        android:paddingEnd="10dp"
        android:clipToPadding="false"
        android:clipChildren="false"
        app:layout_constraintBottom_toBottomOf="parent">

        <androidx.appcompat.widget.AppCompatButton
            android:id="@+id/btnAtras"
            android:layout_width="0dp"
            android:layout_height="50dp"
            android:layout_weight="1"
            android:layout_marginEnd="10dp"
            android:text="Atrás"
            android:textSize="16sp"
            android:textAllCaps="false"
            android:textColor="@color/blanco"
            android:background="@drawable/btn_back" />

        <androidx.appcompat.widget.AppCompatButton
            android:id="@+id/btnSiguientePaso3"
            android:layout_width="0dp"
            android:layout_height="50dp"
            android:layout_weight="1"
            android:layout_marginStart="50dp"
            android:text="Siguiente"
            android:textSize="16sp"
            android:textAllCaps="false"
            android:textColor="@color/blanco"
            android:background="@drawable/btn_next" />
    </LinearLayout>

</androidx.constraintlayout.widget.ConstraintLayout>