<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/blanco"
    android:padding="25dp">

    <ImageButton
        android:id="@+id/btnCerrar"
        android:layout_width="48dp"
        android:layout_height="48dp"
        android:layout_marginTop="25dp"
        android:background="?attr/selectableItemBackgroundBorderless"
        android:scaleType="fitCenter"
        android:src="@drawable/ic_close"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        app:tint="@color/verde_principal" />

    <TextView
        android:id="@+id/tvTituloPaso2"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="@string/confirma_tu_planta"
        android:textColor="@color/verde_principal"
        android:textSize="28sp"
        android:layout_marginTop="25dp"
        app:layout_constraintTop_toBottomOf="@id/btnCerrar"
        app:layout_constraintStart_toStartOf="parent" />

    <com.google.android.material.imageview.ShapeableImageView
        android:id="@+id/ivImagenCapturada"
        android:layout_width="0dp"
        android:layout_height="350dp"
        android:layout_marginTop="25dp"
        android:scaleType="centerCrop"
        android:padding="5dp"
        app:strokeColor="@color/verde_principal"
        app:strokeWidth="4dp"
        app:shapeAppearanceOverlay="@style/MarcoBordes25dp"
        app:layout_constraintTop_toBottomOf="@id/tvTituloPaso2"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <TextView
        android:id="@+id/tvNombrePlanta"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="25dp"
        android:text="Monstera"
        android:textColor="@color/gris_texto"
        android:textSize="32sp"
        app:layout_constraintTop_toBottomOf="@id/ivImagenCapturada"
        app:layout_constraintStart_toStartOf="parent" />

    <TextView
        android:id="@+id/tvNombreCientifico"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Monstera deliciosa"
        android:textColor="@color/gris_texto"
        android:textSize="18sp"
        android:textStyle="italic"
        app:layout_constraintTop_toBottomOf="@id/tvNombrePlanta"
        app:layout_constraintStart_toStartOf="parent" />

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:layout_marginBottom="25dp"
        app:layout_constraintBottom_toBottomOf="parent">

        <androidx.appcompat.widget.AppCompatButton
            android:id="@+id/btnAtras"
            android:layout_width="0dp"
            android:layout_height="50dp"
            android:layout_weight="1"
            android:layout_marginEnd="10dp"
            android:text="Atrás"
            android:textSize="16sp"
            android:textAllCaps="false"
            android:textColor="@color/blanco"
            android:background="@drawable/btn_back" />

        <androidx.appcompat.widget.AppCompatButton
        android:id="@+id/btnSiguientePaso2"
        android:layout_width="0dp"
        android:layout_height="50dp"
        android:layout_weight="1"
        android:layout_marginStart="50dp"
        android:text="Siguiente"
        android:textSize="16sp"
        android:textAllCaps="false"
        android:textColor="@color/blanco"
        android:background="@drawable/btn_next" />
    </LinearLayout>

</androidx.constraintlayout.widget.ConstraintLayout>